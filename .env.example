# ─────────────────────────────────────────────────────────────────────────────
# Supabase credentials
#
# Find these under: Supabase Dashboard → Project Settings → API
#   https://supabase.com/dashboard/project/_/settings/api
#
# Both values are safe to expose to the browser (the anon key is governed by
# Row Level Security), which is why they use the NEXT_PUBLIC_ prefix.
#
# If these are left unset, the dashboard renders a bundled sample dataset so the
# UI is fully functional locally. Set them to fetch live data from your project.
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
